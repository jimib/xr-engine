# Copy this file to .env.local and fill in your 8th Wall engine URLs.
#
# These URLs come from the 8th Wall Buildable Code Export.
# See: https://www.8thwall.com/docs/migration/self-hosted/
#
# NOTE: The "3D Viewer" experience works WITHOUT these URLs.
# Only the "World AR" and "Face AR" experiences require them.

VITE_XR8_ENGINE_URL=
VITE_XR8_EXTRAS_URL=
